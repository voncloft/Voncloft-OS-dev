# description   : VLC is a media player, streamer, and encoder
# depends       : alsalib desktopfileutils ffmpeg liba52 libgcrypt libmadb lua qt chapter24graphicalenvironments

name=vlc
version=3.0.23
release=1
source="https://download.videolan.org/vlc/3.0.23/vlc-3.0.23.tar.xz"

options="!checksum"

build() {
    cd $name-$version
    
    BUILDCC=gcc ./configure --prefix=/usr --disable-libplacebo --disable-lua --enable-avcodec --enable-avformat --enable-swscale --enable-dvbpsi
    make
    #gtk-update-icon-cache -qtf /usr/share/icons/hicolor 
    #update-desktop-database -q
    make DESTDIR=$PKG docdir=/usr/share/doc/vlc-3.0.23 install
}
