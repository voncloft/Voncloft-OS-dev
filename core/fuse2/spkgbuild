# description   : FUSE (Filesystem in Userspace) is a simple interface for userspace programs to export a virtual filesystem to the Linux kernel
# depends       : 

name=fuse2
version=3.18.1    
release=1
source="https://github.com/libfuse/libfuse/releases/download/fuse-3.18.1/fuse-3.18.1.tar.gz"

options="!checksum"

build() {
    cd fuse-$version
    
    sed -i '/^udev/,$ s/^/#/' util/meson.build 
    mkdir build 
    cd    build 
    meson setup --prefix=/usr --buildtype=release .. 
    ninja
    DESTDIR=$PKG ninja install                  
    chmod u+s $PKG/usr/bin/fusermount3 
mkdir -pv $PKG/etc
cat > $PKG/etc/fuse.conf << "EOF"
    # Set the maximum number of FUSE mounts allowed to non-root users.
    # The default is 1000.
    #
    #mount_max = 1000
    # Allow non-root users to specify the 'allow_other' or 'allow_root'
    # mount options.
    #
    #user_allow_other
EOF
}
