# description : broker-less messaging library
# depends : glibc wolfssl cmake git ninja

name=nng
version=1.11
release=2

source="https://github.com/nanomsg/nng/archive/refs/tags/v$version.tar.gz"

build()
{
	cd *
	mkdir build
	cd build
	cmake .. \
	   -DCMAKE_BUILD_TYPE=None \
    -DCMAKE_INSTALL_PREFIX=/usr \
    -DBUILD_SHARED_LIBS=ON \
    -DNNG_ENABLE_TLS=ON \
    -DNNG_TLS_ENGINE=wolf \
    -DNNG_ENABLE_DOC=OFF \
    -DNNG_TESTS=OFF

	make
	make DESTDIR=$PKG install
}
