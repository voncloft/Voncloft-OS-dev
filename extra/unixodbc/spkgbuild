# description   : The unixODBC package is an Open Source ODBC (Open DataBase Connectivity) sub-system and an ODBC SDK for Linux, Mac OSX, and UNIX
# depends       : 

name=unixodbc
version=2.3.14
release=1
source="https://github.com/lurcher/unixODBC/archive/v$version/unixODBC-$version.tar.gz"
options="!checksum"

build() {
        cd *
        autoreconf -fiv 
./configure --prefix=/usr --sysconfdir=/etc/unixODBC 
make
make DESTDIR=$PKG install 
find doc -name "Makefile*" -delete                
chmod 644 doc/{lst,ProgrammerManual/Tutorial}/*   
install -v -m755 -d $PKG/usr/share/doc/unixODBC-2.3.14 
cp      -v -R doc/* $PKG/usr/share/doc/unixODBC-2.3.14
}
