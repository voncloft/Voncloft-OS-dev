# description : circuit simulator
# depends : libx11 libxaw libxt ncurses readline

name=ngspice
version=45.2
release=1

source="https://downloads.sourceforge.net/project/$name/ng-spice-rework/$version/$name-$version.tar.gz"

build()
{
	cd *
	autoreconf -ifv
	./configure --prefix=/usr \
	--mandir=/usr/share/man \
	--infodir=/usr/share/info \
	--with-readline=yes \
	--enable-xspice \
	--enable-cider \
	--enable-openmp \
	--disable-debug \
	--with-ngshared

	make
	make DESTDIR=$PKG install
}
