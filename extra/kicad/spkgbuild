# depends : abseil-cpp cairo curl fontconfig freetype2 gcc glib glibc glm gtk3 harfbuzz hicolor-icon-theme
# depends : libgit2 libglvnd libsecret ngspice nng opencascade protobuf python 
# depends : unixodbc wayland wxwidgets zlib
# depends : zlib zstd kicad-library boost cmake git mesa ninja swig

name=kicad
version=9.0.7
release=5

source="https://github.com/KiCad/kicad-source-mirror/archive/refs/tags/$version.tar.gz"

build()
{

	cd *
	mkdir build
	cd build
cmake .. \
  -DCMAKE_BUILD_TYPE=Release \
  -DCMAKE_INSTALL_PREFIX=/usr \
  -DKICAD_USE_EGL=OFF \
  -DKICAD_BUILD_I18N=ON \
  -DKICAD_I18N_UNIX_STRICT_PATH=ON \
  -DKICAD_BUILD_QA_TESTS=OFF \
  -DKICAD_USE_CMAKE_FINDPROTOBUF=OFF \
  -DKICAD_USE_BUNDLED_GLEW=ON \
  -DKICAD_SCRIPTING_WXPYTHON=ON \
  -DPYTHON_EXECUTABLE=/usr/bin/python3
	make
	make DESTDIR=$PKG install

}
